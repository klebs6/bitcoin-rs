#!/usr/bin/env python3
from pathlib import Path
import re
import subprocess
import sys

crate_dir = Path(sys.argv[1]) if len(sys.argv) > 1 else Path(".")

old_hyphen_map = {
    "bitcoinleveldb-test": "bitcoinleveldbt-deleteme",
    "bitcoinleveldb-testautocompaction": "bitcoinleveldbt-autocompaction",
    "bitcoinleveldb-testcapi": "bitcoinleveldbt-capi",
    "bitcoinleveldb-testcorruption": "bitcoinleveldbt-corruption",
    "bitcoinleveldb-testenv": "bitcoinleveldbt-env",
    "bitcoinleveldb-testfaultinjection": "bitcoinleveldbt-faultinjection",
    "bitcoinleveldb-testissue178": "bitcoinleveldbt-issue178",
    "bitcoinleveldb-testissue200": "bitcoinleveldbt-issue200",
    "bitcoinleveldb-testissue320": "bitcoinleveldbt-issue320",
    "bitcoinleveldb-testmt": "bitcoinleveldbt-mt",
    "bitcoinleveldb-testrandomized": "bitcoinleveldbt-randomized",
    "bitcoinleveldb-testrecovery": "bitcoinleveldbt-recovery",
    "bitcoinleveldb-testsnapshot": "bitcoinleveldbt-snapshot",
    "bitcoinleveldb-testtable": "bitcoinleveldbt-table",
    "bitcoinleveldb-testutil": "bitcoinleveldbt-util",
    "bitcoinleveldb-versionsettestutil": "bitcoinleveldbt-versionsettestutil",
    "bitcoinleveldb-mockversionset": "bitcoinleveldbt-mockversionset",
    "bitcoinleveldb-dbtest": "bitcoinleveldbt-dbtest",
}

hyphen_map = {
    "bitcoinleveldb-bench": "bitcoinleveldbt-bench",
}

full_map = dict(hyphen_map)
full_map.update({
    k.replace("-", "_"): v.replace("-", "_")
    for k, v in hyphen_map.items()
})

# 1. rename crate directories on disk/index
for old, new in hyphen_map.items():
    old_path = crate_dir / old
    new_path = crate_dir / new
    if old_path.exists():
        print(f"git mv {old_path} {new_path}")
        subprocess.run(["git", "mv", str(old_path), str(new_path)], check=True)

# 2. rewrite tracked text files with exact-token boundaries
alts = "|".join(sorted((re.escape(k) for k in full_map), key=len, reverse=True))
pat = re.compile(r'(?<![A-Za-z0-9_])(' + alts + r')(?![A-Za-z0-9_])')

for raw in subprocess.check_output(["git", "ls-files", "-z"]).split(b"\0"):
    if not raw:
        continue
    p = Path(raw.decode())
    try:
        old_text = p.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        continue
    new_text = pat.sub(lambda m: full_map[m.group(1)], old_text)
    if new_text != old_text:
        p.write_text(new_text, encoding="utf-8")
        print(f"rewrote {p}")
