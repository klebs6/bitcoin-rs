        let keyn = self.key(n);
        let last_key = self.key(COUNT);
    
        // Get initial measurement of the space we will be reading.
        let initial_size = self.size(
            &Slice::from(&key0),
            &Slice::from(&keyn),
        );
        let initial_other_size = self.size(
            &Slice::from(&keyn),
            &Slice::from(&last_key),
