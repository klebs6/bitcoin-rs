            self.mmap_limiter_mut().release();
    
            return posix_error(filename, errno);
        }
    
        unsafe {
            libc::close(fd);
        }
    
        debug!(
            file   = %filename,
            length,
            "PosixEnv::new_random_access_file: mmap() succeeded"
        );
    
        let mmap_file = PosixMmapReadableFile::new(
            filename.clone(),
            mmap_base as *mut u8,
            length,
            &mut *self.mmap_limiter_mut() as *mut Limiter,
