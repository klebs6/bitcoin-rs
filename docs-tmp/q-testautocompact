        //    dir/foo
        // rename to
        //    dir/lost/foo
        let slash_pos = fname.rfind('/');
    
        let mut new_dir = String::new();
        if let Some(pos) = slash_pos {
            new_dir.push_str(&fname[..pos]);
        }
        new_dir.push_str("/lost");
    
