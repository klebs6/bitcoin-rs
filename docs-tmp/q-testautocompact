        let handles: Vec<*mut CacheHandle> = self.entries.values().copied().collect();
        self.entries.clear();
    
        for handle in handles {
            unsafe {
                let h = &mut *handle;
                if *h.in_cache() {
                    self.usage = self.usage.saturating_sub(*h.charge());
                    h.set_in_cache(false);
                }
            }
            self.unref_entry(handle);
        }
    
        self.usage = 0;
