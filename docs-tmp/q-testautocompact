            i += 1i32;
        }
    
        let compact_status = unsafe { (&mut *dbi).test_compact_mem_table() };
        assert!(compact_status.is_ok());
    
        // Delete everything
        i = 0i32;
        while i < COUNT {
            let key = self.key(i);
            let status = unsafe {
                (&mut *self.db).delete(
                    &WriteOptions::default(),
                    &Slice::from(&key),
                )
            };
            assert!(status.is_ok());
