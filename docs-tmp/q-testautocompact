            return store_posix_env_boxed_result::<dyn RandomAccessFile>(
                CALLER,
                result,
                inner,
            );
        }
    
        let mmap_base = unsafe {
            libc::mmap(
                std::ptr::null_mut(),
                length,
                libc::PROT_READ,
                libc::MAP_SHARED,
                fd,
                0,
            )
