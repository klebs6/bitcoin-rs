        let dbi: *mut DBImpl = (self.db as *mut ()) as *mut DBImpl;
    
        // Fill database
        let mut i: i32 = 0i32;
        while i < COUNT {
            let key = self.key(i);
            let status = unsafe {
                (&mut *self.db).put(
                    &WriteOptions::default(),
                    &Slice::from(&key),
                    &Slice::from(&value),
