pub fn bitcoinleveldb_dbimpl_live_compaction_boundary_build_internal_key_for_entry(user_key: &str, sequence_number: u64, entry_kind: &BitcoinLevelDbDbImplLiveCompactionEntryKind) -> InternalKey {
