                file = %filename,
                fd,
                "PosixEnv::new_random_access_file: zero-length file; \
                 falling back to fd-based random access file"
            );
    
            self.mmap_limiter_mut().release();
    
            let ra = PosixRandomAccessFile::new(
                filename.clone(),
                fd,
                &mut *self.fd_limiter_mut() as *mut Limiter,
